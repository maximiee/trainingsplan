# Session-Secret (bitte vor dem ersten Start ändern!)
SESSION_SECRET=bitte_aendern_langes_zufaelliges_passwort

# Datenbankpfad (Standard für Docker)
DB_PATH=/app/data/trainingsplan.db

# Erster Admin-Account
ADMIN_EMAIL=admin@verein.de
ADMIN_PASSWORD=changeme123

# Vereinsname (für Export-Fußzeile)
CLUB_NAME=Fussballverein

# E-Mail-Benachrichtigungen (optional – wenn nicht gesetzt, werden keine Mails verschickt)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=trainingsplan@example.com
SMTP_PASS=passwort
SMTP_FROM="Trainingsplan <trainingsplan@example.com>"
